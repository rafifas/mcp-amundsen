# URL of your Amundsen metadata service (default port 5000)
AMUNDSEN_API_URL=http://localhost:5000

# URL of your Amundsen search service (default port 5001)
AMUNDSEN_SEARCH_API_URL=http://localhost:5001

# MCP server bind host (use 0.0.0.0 for Docker)
FASTMCP_HOST=127.0.0.1

# MCP server port
FASTMCP_PORT=8000

# Amundsen cluster name used in table key format (default: gold)
# Only change this if your Amundsen deployment uses a non-standard cluster name
AMUNDSEN_CLUSTER_NAME=gold

# HTTP request timeout in seconds for Amundsen API calls (default: 30)
AMUNDSEN_REQUEST_TIMEOUT_SECONDS=30
